---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import Comments from '../components/Comments.astro';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate, heroImage, toolLogo, rating, verdict } = Astro.props;

const toolName = title.split(/[:,–—]/)[0].replace(/review|Review|REVIEW/gi, '').trim();

const verdictConfig = {
	recommended: { label: 'Recommended', color: 'text-green-600' },
	conditional: { label: 'Conditional', color: 'text-amber-600' },
	'not-recommended': { label: 'Not Recommended', color: 'text-red-600' },
};
const v = verdict ? verdictConfig[verdict] : verdictConfig.recommended;
---

<html lang="en">
	<head>
		<BaseHead title={`${title} | SaaSScout`} description={description} />
	</head>
	<body class="bg-white font-sans text-gray-900 antialiased">
		<Header />
		<main class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
			<article>
				{heroImage && (
					<div class="mb-8">
						<Image width={720} height={360} src={heroImage} alt="" class="w-full rounded-xl shadow-sm" />
					</div>
				)}

				<header class="mb-8">
					<div class="flex items-center gap-3 mb-4">
						<span class="text-xs font-semibold px-2.5 py-1 rounded-full uppercase tracking-wide bg-blue-100 text-blue-700">
							★ Review
						</span>
						<span class="text-sm text-gray-400">
							<FormattedDate date={pubDate} />
						</span>
						{updatedDate && (
							<span class="text-sm text-gray-400 italic">
								Updated <FormattedDate date={updatedDate} />
							</span>
						)}
					</div>
					<h1 class="text-3xl sm:text-4xl font-bold leading-tight mb-3">{title}</h1>
					<p class="text-lg text-gray-500">{description}</p>
				</header>

				<!-- Review info bar -->
				<div class="bg-slate-50 border border-gray-200 rounded-xl p-5 mb-10">
					<div class="flex items-center gap-4 mb-4">
						{toolLogo ? (
							<Image width={48} height={48} src={toolLogo} alt={toolName} class="w-12 h-12 rounded-lg" />
						) : (
							<div class="w-12 h-12 bg-indigo-100 rounded-lg flex items-center justify-center shrink-0">
								<span class="text-indigo-600 font-bold text-lg">{toolName.charAt(0)}</span>
							</div>
						)}
						<div>
							<p class="text-sm font-bold text-gray-900 m-0">{toolName}</p>
							<p class="text-xs text-gray-500 m-0">Reviewed by SaaSScout</p>
						</div>
					</div>
					<div class="grid grid-cols-3 gap-4 text-center pt-4 border-t border-gray-200">
						<div>
							<p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Rating</p>
							<p class="text-sm font-bold text-indigo-600">{rating ? `${rating}/10` : '—'}</p>
						</div>
						<div>
							<p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Last Tested</p>
							<p class="text-sm font-semibold text-gray-700"><FormattedDate date={pubDate} /></p>
						</div>
						<div>
							<p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Verdict</p>
							<p class={`text-sm font-semibold ${v.color}`}>{v.label}</p>
						</div>
					</div>
				</div>

				<div class="prose">
					<slot />
				</div>
			</article>

			<Comments toolName={toolName} />

			<div class="mt-10">
				<NewsletterForm variant="inline" heading="Liked this review?" description="Get one honest tool review per week. No spam, no sponsored rankings." />
			</div>

			<div class="mt-8 pt-8 border-t border-gray-200">
				<a href="/blog" class="text-indigo-600 font-medium hover:text-indigo-800 no-underline">
					← Back to all reviews
				</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
