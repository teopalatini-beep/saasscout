---
import FormattedDate from './FormattedDate.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	category?: string;
	slug: string;
}

const { title, description, pubDate, category, slug } = Astro.props;

const categoryConfig: Record<string, { bg: string; badge: string; icon: string; border: string }> = {
	review: {
		bg: 'bg-slate-50',
		badge: 'bg-blue-100 text-blue-700',
		icon: '★',
		border: 'hover:border-blue-300',
	},
	comparison: {
		bg: 'bg-gray-50',
		badge: 'bg-purple-100 text-purple-700',
		icon: '⇄',
		border: 'hover:border-purple-300',
	},
	listicle: {
		bg: 'bg-stone-50',
		badge: 'bg-green-100 text-green-700',
		icon: '#',
		border: 'hover:border-green-300',
	},
	tutorial: {
		bg: 'bg-zinc-50',
		badge: 'bg-amber-100 text-amber-700',
		icon: '▶',
		border: 'hover:border-amber-300',
	},
	guide: {
		bg: 'bg-neutral-50',
		badge: 'bg-rose-100 text-rose-700',
		icon: '📖',
		border: 'hover:border-rose-300',
	},
};

const config = category ? categoryConfig[category] : null;
const bgClass = config?.bg || 'bg-white';
const badgeClass = config?.badge || 'bg-gray-100 text-gray-700';
const borderClass = config?.border || 'hover:border-gray-300';
const icon = config?.icon || '';
---

<a href={`/blog/${slug}/`} class="group block no-underline">
	<article class:list={[
		'border border-gray-200 rounded-xl p-6 transition-all duration-200',
		'hover:shadow-lg hover:-translate-y-1 cursor-pointer',
		bgClass,
		borderClass,
	]}>
		<div class="flex items-center justify-between mb-4">
			<div class="flex items-center gap-2">
				{category && (
					<span class={`text-xs font-semibold px-2.5 py-1 rounded-full uppercase tracking-wide ${badgeClass}`}>
						{icon} {category}
					</span>
				)}
			</div>
			<span class="text-xs text-gray-400">
				<FormattedDate date={pubDate} />
			</span>
		</div>

		<h3 class="text-lg font-bold text-gray-900 group-hover:text-indigo-600 transition-colors mb-2 leading-snug">
			{title}
		</h3>

		<p class="text-sm text-gray-500 leading-relaxed line-clamp-2 mb-4">
			{description}
		</p>

		<div class="flex items-center text-indigo-600 text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-200">
			Read more →
		</div>
	</article>
</a>
