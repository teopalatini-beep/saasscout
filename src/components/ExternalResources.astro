---
interface Resource {
	title: string;
	url: string;
	source: string;
	type?: 'review' | 'official' | 'comparison' | 'tutorial' | 'community';
}

interface Props {
	resources: Resource[];
}

const { resources } = Astro.props;

const typeConfig: Record<string, { label: string; color: string }> = {
	review: { label: 'Review', color: 'bg-blue-50 text-blue-600' },
	official: { label: 'Official', color: 'bg-gray-100 text-gray-600' },
	comparison: { label: 'Comparison', color: 'bg-purple-50 text-purple-600' },
	tutorial: { label: 'Tutorial', color: 'bg-amber-50 text-amber-600' },
	community: { label: 'Community', color: 'bg-green-50 text-green-600' },
};
---

<div class="not-prose my-10 border border-gray-200 rounded-xl overflow-hidden">
	<div class="bg-gray-50 px-5 py-3 border-b border-gray-200">
		<h3 class="text-sm font-bold text-gray-700 m-0">Keep researching</h3>
		<p class="text-xs text-gray-500 mt-0.5">Trusted external sources to help you decide.</p>
	</div>
	<ul class="divide-y divide-gray-100 m-0 p-0 list-none">
		{resources.map((r) => {
			const t = typeConfig[r.type || 'review'];
			return (
				<li class="m-0 p-0">
					<a
						href={r.url}
						target="_blank"
						rel="noopener noreferrer"
						class="flex items-center justify-between px-5 py-3.5 no-underline hover:bg-gray-50 transition-colors group"
					>
						<div class="min-w-0">
							<p class="text-sm font-medium text-gray-900 group-hover:text-indigo-600 transition-colors truncate m-0">
								{r.title}
							</p>
							<p class="text-xs text-gray-400 mt-0.5 m-0">{r.source}</p>
						</div>
						<div class="flex items-center gap-2 shrink-0 ml-4">
							{t && (
								<span class={`text-[10px] font-semibold px-2 py-0.5 rounded-full uppercase tracking-wide ${t.color}`}>
									{t.label}
								</span>
							)}
							<span class="text-gray-300 group-hover:text-indigo-400 transition-colors text-sm">↗</span>
						</div>
					</a>
				</li>
			);
		})}
	</ul>
</div>
