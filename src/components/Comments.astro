---
interface Props {
	toolName?: string;
}

const { toolName } = Astro.props;

// ============================================================
// TO CONNECT GISCUS (free comments via GitHub Discussions):
// 1. Go to https://giscus.app
// 2. Enter your repo: teopalatini-beep/saasscout
// 3. Enable Discussions on your repo (Settings → Features → Discussions)
// 4. Choose category: "Reviews" (create it in Discussions tab)
// 5. Copy the data-repo, data-repo-id, data-category, data-category-id
// 6. Replace the placeholders below
// ============================================================
const GISCUS_REPO = 'teopalatini-beep/saasscout';
const GISCUS_REPO_ID = 'R_kgDOSc4MMg';
const GISCUS_CATEGORY = 'Announcements';
const GISCUS_CATEGORY_ID = 'DIC_kwDOSc4MMs4C9MR6';
const isConfigured = GISCUS_REPO_ID !== 'REPO_ID_HERE';
---

<section class="mt-14 pt-10 border-t border-gray-200">
	<div class="mb-6">
		<h2 class="text-xl font-bold text-gray-900 mb-1">
			{toolName ? `What do you think about ${toolName}?` : 'Share your experience'}
		</h2>
		<p class="text-sm text-gray-500">
			Used this tool? Help others decide — leave your honest opinion below.
		</p>
	</div>

	{isConfigured ? (
		<div class="giscus-container">
			<script
				is:inline
				src="https://giscus.app/client.js"
				data-repo={GISCUS_REPO}
				data-repo-id={GISCUS_REPO_ID}
				data-category={GISCUS_CATEGORY}
				data-category-id={GISCUS_CATEGORY_ID}
				data-mapping="pathname"
				data-strict="0"
				data-reactions-enabled="1"
				data-emit-metadata="0"
				data-input-position="top"
				data-theme="light"
				data-lang="en"
				data-loading="lazy"
				crossorigin="anonymous"
				async
			></script>
		</div>
	) : (
		<div class="bg-gray-50 border border-gray-200 rounded-xl p-8 text-center">
			<div class="w-14 h-14 bg-gray-100 rounded-full mx-auto mb-4 flex items-center justify-center">
				<svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
				</svg>
			</div>
			<p class="text-sm font-medium text-gray-700 mb-1">Community reviews coming soon</p>
			<p class="text-xs text-gray-400">Share your experience with this tool and help others decide.</p>
		</div>
	)}
</section>
