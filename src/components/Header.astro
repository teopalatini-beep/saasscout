---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
	<nav class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">
		<a href="/" class="text-xl font-bold text-gray-900 no-underline hover:text-indigo-600 transition-colors">
			{SITE_TITLE}
		</a>
		<div class="flex items-center gap-1">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Reviews</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
