---
import type { HTMLAttributes } from 'astro/types';
type Props = HTMLAttributes<'a'> & { href: string };

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname;
const isActive = href === pathname || href === pathname.replace(/\/$/, '');
---

<a
	href={href}
	class:list={[
		'px-3 py-2 rounded-md text-sm font-medium no-underline transition-colors',
		{
			'bg-indigo-50 text-indigo-700': isActive,
			'text-gray-600 hover:text-gray-900 hover:bg-gray-50': !isActive,
		},
		className,
	]}
	{...props}
>
	<slot />
</a>
