---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const allCategories = ['review', 'comparison', 'listicle', 'tutorial', 'guide'] as const;

export function getStaticPaths() {
	return ['review', 'comparison', 'listicle', 'tutorial', 'guide'].map((cat) => ({
		params: { category: cat },
	}));
}

const { category } = Astro.params;

const posts = (await getCollection('blog'))
	.filter((post) => post.data.category === category)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryLabels: Record<string, string> = {
	review: 'Reviews',
	comparison: 'Comparisons',
	listicle: 'Listicles',
	tutorial: 'Tutorials',
	guide: 'Guides',
};

const categoryDescriptions: Record<string, string> = {
	review: 'In-depth, honest reviews of individual SaaS and AI tools.',
	comparison: 'Head-to-head comparisons to help you pick the right tool.',
	listicle: 'Curated lists of the best tools for specific use cases.',
	tutorial: 'Step-by-step tutorials showing tools in action.',
	guide: 'Complete beginner guides to get you started from scratch.',
};

const label = categoryLabels[category] || category;
const description = categoryDescriptions[category] || '';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${label} | ${SITE_TITLE}`} description={description} />
	</head>
	<body class="bg-white font-sans text-gray-900 antialiased">
		<Header />
		<main class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
			<div class="mb-10">
				<h1 class="text-3xl font-bold mb-2">{label}</h1>
				<p class="text-gray-500">{description}</p>
			</div>

			<!-- Category nav -->
			<div class="flex flex-wrap gap-2 mb-10">
				{allCategories.map((cat) => (
					<a
						href={`/category/${cat}/`}
						class:list={[
							'px-4 py-1.5 text-sm font-medium rounded-full no-underline transition-colors capitalize',
							cat === category
								? 'bg-indigo-600 text-white'
								: 'bg-gray-100 text-gray-600 hover:bg-indigo-100 hover:text-indigo-700',
						]}
					>
						{categoryLabels[cat]}
					</a>
				))}
				<a href="/blog" class="px-4 py-1.5 bg-gray-100 text-gray-600 text-sm font-medium rounded-full no-underline hover:bg-gray-200 transition-colors">
					All
				</a>
			</div>

			{posts.length > 0 ? (
				<div class="grid gap-5 sm:grid-cols-2">
					{posts.map((post) => (
						<PostCard
							title={post.data.title}
							description={post.data.description}
							pubDate={post.data.pubDate}
							category={post.data.category}
							slug={post.id}
						/>
					))}
				</div>
			) : (
				<p class="text-center text-gray-400 py-16">No {label.toLowerCase()} published yet. Check back soon.</p>
			)}
		</main>
		<Footer />
	</body>
</html>
