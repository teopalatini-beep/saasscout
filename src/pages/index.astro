---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = ['review', 'comparison', 'listicle', 'tutorial', 'guide'];

const featuredTools = [
	{ name: 'Systeme.io', tagline: 'All-in-one marketing', commission: '60% recurring', category: 'Marketing', link: '/blog/systeme-io-review/' },
	{ name: 'Jasper AI', tagline: 'AI writing assistant', commission: '30% recurring', category: 'AI Writing', link: '/blog/jasper-ai-review/' },
	{ name: 'TubeBuddy', tagline: 'YouTube growth tool', commission: '50% recurring', category: 'YouTube', link: '/blog/tubebuddy-vs-vidiq/' },
	{ name: 'Surfer SEO', tagline: 'SEO content optimizer', commission: '25% recurring', category: 'SEO', link: '/blog/surfer-seo-review/' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-white font-sans text-gray-900 antialiased">
		<Header />
		<main class="max-w-5xl mx-auto px-4 sm:px-6">
			<!-- Hero -->
			<section class="py-16 sm:py-24 text-center">
				<p class="text-sm font-semibold text-indigo-600 uppercase tracking-widest mb-4">Trusted SaaS Reviews</p>
				<h1 class="text-4xl sm:text-5xl font-bold tracking-tight leading-tight mb-6">
					Find the right tool.<br />
					<span class="text-indigo-600">Skip the noise.</span>
				</h1>
				<p class="text-lg text-gray-500 max-w-xl mx-auto leading-relaxed mb-8">
					Honest reviews and comparisons of AI and SaaS tools
					for freelancers, creators, and small businesses.
					No sponsored rankings. No fluff.
				</p>
				<div class="flex justify-center gap-3">
					<a href="/blog" class="px-6 py-3 bg-indigo-600 text-white font-semibold rounded-lg no-underline hover:bg-indigo-700 transition-colors text-sm">
						Browse Reviews
					</a>
					<a href="/about" class="px-6 py-3 bg-white text-gray-700 font-semibold rounded-lg no-underline border border-gray-300 hover:border-gray-400 transition-colors text-sm">
						How We Review
					</a>
				</div>
			</section>

			<!-- Featured Tools -->
			<section class="pb-16">
				<div class="text-center mb-10">
					<h2 class="text-2xl font-bold mb-2">Top Rated Tools</h2>
					<p class="text-gray-500 text-sm">Hand-picked based on real testing. Updated monthly.</p>
				</div>
				<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
					{featuredTools.map((tool) => (
						<a href={tool.link} class="group block no-underline">
							<div class="bg-gray-50 border border-gray-200 rounded-xl p-5 text-center hover:shadow-md hover:border-indigo-200 hover:-translate-y-0.5 transition-all duration-200">
								<div class="w-12 h-12 bg-indigo-100 rounded-xl mx-auto mb-3 flex items-center justify-center">
									<span class="text-indigo-600 font-bold text-lg">{tool.name.charAt(0)}</span>
								</div>
								<h3 class="font-bold text-gray-900 group-hover:text-indigo-600 transition-colors text-sm">{tool.name}</h3>
								<p class="text-xs text-gray-500 mt-1">{tool.tagline}</p>
								<span class="inline-block mt-3 text-xs font-medium text-green-700 bg-green-50 px-2.5 py-1 rounded-full">
									{tool.commission}
								</span>
							</div>
						</a>
					))}
				</div>
			</section>

			<!-- Categories -->
			<section class="flex flex-wrap justify-center gap-2 mb-12">
				{categories.map((cat) => (
					<a href={`/category/${cat}/`} class="px-4 py-1.5 bg-gray-100 text-gray-600 text-sm font-medium rounded-full capitalize no-underline hover:bg-indigo-100 hover:text-indigo-700 transition-colors">
						{cat}s
					</a>
				))}
			</section>

			<!-- Latest posts -->
			<section class="pb-16">
				<h2 class="text-2xl font-bold mb-8">Latest Articles</h2>
				<div class="grid gap-5 sm:grid-cols-2">
					{posts.map((post) => (
						<PostCard
							title={post.data.title}
							description={post.data.description}
							pubDate={post.data.pubDate}
							category={post.data.category}
							slug={post.id}
						/>
					))}
				</div>
				{posts.length === 0 && (
					<p class="text-center text-gray-400 py-12">No reviews yet. Check back soon.</p>
				)}
			</section>

			<!-- Newsletter -->
			<section class="pb-20">
				<NewsletterForm variant="banner" />
			</section>
		</main>
		<Footer />
	</body>
</html>
