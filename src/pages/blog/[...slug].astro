---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import ReviewLayout from '../../layouts/ReviewLayout.astro';
import ComparisonLayout from '../../layouts/ComparisonLayout.astro';
import GuideLayout from '../../layouts/GuideLayout.astro';
import TutorialLayout from '../../layouts/TutorialLayout.astro';
import ListicleLayout from '../../layouts/ListicleLayout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

const layouts = {
	review: ReviewLayout,
	comparison: ComparisonLayout,
	guide: GuideLayout,
	tutorial: TutorialLayout,
	listicle: ListicleLayout,
};

const Layout = layouts[post.data.category || 'review'] || ReviewLayout;
---

<Layout {...post.data}>
	<Content />
</Layout>
